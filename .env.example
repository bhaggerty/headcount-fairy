# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
PORT=8080

# Slack User IDs — roles
SLACK_USER_HIRING_LEAD=U...
SLACK_USER_EXEC_APPROVER=U...
SLACK_USER_TALENT_COORDINATOR=U...
SLACK_USER_GTM_RECRUITER=U...
SLACK_USER_TECH_RECRUITER=U...
SLACK_USER_GENERAL_RECRUITER=U...

# AWS — Bedrock (Claude, for JD/interview-guide generation) + DynamoDB (req state)
# Table name and region are injected automatically by Union Station in production.
# For local runs you'll also need AWS credentials that can reach both services
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, or a configured profile).
APP_DYNAMODB_TABLE_NAME=
AWS_REGION=

# Ashby
ASHBY_API_KEY=...

# Google Sheets (via Apps Script — see apps-script.js)
APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
APPS_SCRIPT_SECRET=your-random-secret-key
